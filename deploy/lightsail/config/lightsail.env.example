# Copy to deploy/lightsail/config/lightsail.env and fill values.
# This file is consumed by deploy/lightsail/scripts/*.sh.

# ===== DNS and domains =====
DOMAIN_ROOT=example.com
RECRUITER_DOMAIN=recruiter.example.com
CANDIDATE_DOMAIN=candidate.example.com
API_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=devops@example.com

# ===== Lightsail metadata =====
AWS_REGION=ap-south-1
LIGHTSAIL_INSTANCE_NAME=aegis-showcase
SNAPSHOT_RETENTION_COUNT=7

# ===== App checkout =====
REPO_URL=git@github.com:your-org/aegis-forge.git
REPO_BRANCH=main
APP_DIR=/opt/aegis-forge
APP_USER=ubuntu
UPLOADS_DIR=/var/lib/aegis/uploads

# ===== Runtime env shared by backend/agent =====
LIVEKIT_URL=wss://your-livekit-url.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me
GROQ_API_KEY=replace-me
DEEPGRAM_API_KEY=replace-me
SIMLI_API_KEY=
SIMLI_FACE_ID=

# ===== Frontend public env =====
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-url.livekit.cloud

# ===== Optional tuning =====
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000
